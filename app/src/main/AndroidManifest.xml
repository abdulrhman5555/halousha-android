<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        
        <!-- Main Activity that holds our WebView container -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication" />

        <!-- Default launcher activity alias -->
        <activity-alias
            android:name=".MainActivityAliasDefault"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Teal theme launcher activity alias -->
        <activity-alias
            android:name=".MainActivityAliasTeal"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_teal"
            android:roundIcon="@drawable/ic_launcher_teal"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Purple theme launcher activity alias -->
        <activity-alias
            android:name=".MainActivityAliasPurple"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_purple"
            android:roundIcon="@drawable/ic_launcher_purple"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Gold theme launcher activity alias -->
        <activity-alias
            android:name=".MainActivityAliasGold"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_gold"
            android:roundIcon="@drawable/ic_launcher_gold"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
